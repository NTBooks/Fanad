# ── Fanad environment — copy to .env (which is gitignored). Never commit .env. ──

# Server
PORT=8787
NODE_ENV=development

# TZ: the server's timezone (IANA name, e.g. America/New_York) — normally LEAVE BLANK. Day boundaries —
# the calorie log, journal entries, "today" tallies — follow the server's clock (with a 02:00 rollover: a
# 1am snack still counts as the evening's day), and the app adopts the timezone of your WEATHER LOCATION
# (Settings → Weather) automatically, so a UTC container still keeps your wall-clock time. Set TZ only to
# OVERRIDE that (e.g. no location set, or the geocoded zone is wrong) — an explicit TZ always wins.
TZ=

# ── Persistent storage (containers / Coolify) ──
# The DB + encryption key live under this dir. On a container host the filesystem is EPHEMERAL, so map a
# persistent volume to this path (in Coolify: Storages → mount a volume at /persist) or data is lost on
# redeploy. Default /persist. In production the app refuses to start if it isn't mounted (fail-fast).
# Local dev with no /persist falls back to ./data automatically. DATA_DIR (below) overrides this entirely.
PERSIST_DATA=/persist
# DATA_DIR: explicit override for where data lives (wins over PERSIST_DATA). Leave blank normally.
DATA_DIR=

# ── Web login (auth §9) ──
# AUTH_MODE: the DEFAULT auth mode before an in-app choice is made — none (open web UI, today's trust
# model) | simple (username + password + MANDATORY TOTP 2FA). The Settings → Security dropdown writes the
# choice to the DB, which wins over this from then on. Enabling 'simple' requires the root user to have set
# a username, password, and a verified authenticator first (Settings → Security, while the mode is off).
AUTH_MODE=
# AUTH_RESET: break-glass lockout recovery (lost phone / lost KEK). Set to 1 and restart: web login is
# forced OFF (credentials + 2FA are preserved), a loud banner prints, and you can reach Settings again.
# UNSET it afterwards or login can't be re-enabled across restarts.
AUTH_RESET=
# TRUST_PROXY: set to 1 (or a hop count) when behind a reverse proxy (Coolify/Traefik) so req.ip reflects
# the real client — the web IP allowlist and the login rate-limit key on it. Leave blank when serving directly.
TRUST_PROXY=

# SESSION_SECRET: unused — web sessions are opaque random tokens stored hashed in the DB, no signing needed.
SESSION_SECRET=

# ── Web appearance ──
# WEB_DEFAULT_THEME: theme for browsers that haven't picked one — auto (default) | light | dark | bokeh.
# 'bokeh' is the 🌊 Ocean theme (animated day/night sea) — the public demo sets it for the first
# impression. A visitor's own pick in Settings → Appearance is remembered per browser and always wins.
WEB_DEFAULT_THEME=

# ── Secret encryption (KEK) ──
# Key-encryption key for secrets stored in the DB (LLM API keys, Telegram token). API keys are very
# stealable, so they're encrypted at rest (AES-256-GCM). 32 bytes, base64 (or 64-char hex).
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# At boot the app reads this, keeps it in memory, and DELETES it from process.env (anti-enumeration).
# Real use: keep .env in a password manager, inject with a loader. For debug, here in .env is fine.
#
# If KEK is BLANK, the app auto-generates an on-box BOOTSTRAP key file (see KEK_FILE) so secrets are
# still encrypted (never plaintext) — a stopgap. When you later set KEK, the next boot re-encrypts every
# secret under it and deletes the bootstrap file. Caveat: a bootstrap key on the same box as the DB only
# protects against DB-only leaks, NOT box theft — the env KEK is what defends against that.
KEK=
# Where the bootstrap key lives. Default: a ".kek" sibling of DATA_DIR (so a backup of data/ excludes it).
# Point it OUTSIDE your backup set to keep the bootstrap key's (small) protection meaningful.
KEK_FILE=

# ── Instance backup (migrate this install to another server) ──
# BACKUP_MODE=1 unlocks Settings → Data & privacy → Backup: download the WHOLE installation (database,
# settings, photos, retention archives) as one zip, with a checkbox to also include the encryption key
# file. Restore the zip by dropping it onto a fresh install's setup wizard, or "npm run restore" on a
# headless server. Off (blank) by default and deliberately an env flag, not a setting: the backup is the
# entire database in one file, so the capability requires a restart-level decision to expose — turn it on
# for a migration or an occasional full backup, then turn it back off. Works in production (unlike
# SETUP_MODE). If web login is off, ANYONE who can reach the server can download the backup while this
# flag is on — enable web login first on any networked deployment.
BACKUP_MODE=

# ── LLM provider ──
# LLM_PROVIDER  = CHAT backend:       lmstudio (default, local) | ollama (local) | openai | gemini | anthropic
# EMBED_PROVIDER = EMBEDDINGS backend: lmstudio | ollama | openai | gemini   (Anthropic has NO embeddings API)
# Local providers (lmstudio, ollama) keep everything private. Cloud providers send your notes OFF your machine.
# LLM_ALLOW_CLOUD: gate the cloud providers. OFF by default → only local providers show in Settings, the API
# refuses cloud providers, AND the runtime hard-blocks them. Set to 1/true to expose & allow openai|gemini|anthropic.
LLM_ALLOW_CLOUD=
LLM_PROVIDER=lmstudio
EMBED_PROVIDER=lmstudio

# LM Studio (local, default).
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
LMSTUDIO_CHAT_MODEL=
LMSTUDIO_EMBED_MODEL=
LMSTUDIO_API_KEY=lm-studio

# Ollama (local, OpenAI-compatible). Run models on this computer: install Ollama, then e.g.
#   ollama pull llama3.2        (a chat model)
#   ollama pull nomic-embed-text (an embedding model, for RAG)
# Shares the LM Studio fields above; if both are blank the default base URL is http://127.0.0.1:11434/v1.
OLLAMA_BASE_URL=

# Optional cloud LLMs (bring your own key). Leave blank unless LLM_PROVIDER/EMBED_PROVIDER points at one.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=text-embedding-004
ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-6

# ── Public-demo guardrails (all optional; blank/0 = off, today's private-box behavior) ──
# Cost/abuse caps for running vouched-in strangers, especially on a paid cloud key. Owner/root is ALWAYS
# exempt. Suggested demo values in parentheses. Runtime kill switches (demo pause / vouch freeze) are
# in-app: the owner's `demo` chat command or Settings → Security — not env.
# Per-user LLM calls (chat + embeddings) per day; over the cap the bot replies with a friendly limit
# notice and simple commands keep working. (150)
LLM_USER_DAILY_CALL_CAP=
# Global in-flight LLM provider calls; excess queue FIFO. (3)
LLM_MAX_CONCURRENCY=
# Max queued calls beyond the concurrency cap; overflow gets a friendly "busy, try again" reply. (25)
LLM_QUEUE_MAX=
# Max active vouches a non-owner may give ("invites"). (3)
VOUCH_CAP_PER_USER=
# Max vouch-chain depth: owner=0, owner-vouched users=1, and so on; a user at the max depth cannot vouch
# further. 2 = guests-of-guests can't invite. (2)
VOUCH_MAX_DEPTH=
# Global cap on active vouched-in users per platform ("seats"). (50)
MAX_VOUCHED_USERS=
# Hours before a /demo self-signup's seat is reclaimed if they never send a first message (the scheduler
# soft-revokes the unclaimed vouch so the seat frees up). Only affects the /demo cohort. 0 = off. (2)
DEMO_SEAT_RECLAIM_HOURS=
# Max seats one IP address may claim via the public /demo form (24h rolling) — stops one actor hoarding the
# guest list with junk handles, with room for an honest typo-retry. Also caps per-IP browser (web) signups. (3)
DEMO_SIGNUPS_PER_IP=
# Global cap on self-registered BROWSER demo accounts (auth mode simple + registration on) — the web analogue
# of MAX_VOUCHED_USERS, which only counts Telegram vouches. Only enforced while demo mode ("demo signup on")
# is active. 0 = off. (0)
MAX_WEB_DEMO_ACCOUNTS=
# Max characters of an inbound message stored verbatim; longer text is truncated with a marker. Telegram
# already caps messages at 4096 — this mainly bounds the web/API path. (4000)
MAX_INBOUND_CHARS=

# ── Link previews ──
# Pasting a URL as a task fetches the page's title/description ONCE at capture (SSRF-guarded: public hosts
# only, 4s timeout, 64KB cap) and renders the task title as a clickable link. LINK_PREVIEW=off disables the
# fetch entirely — the URL files as plain text, like before. (on)
LINK_PREVIEW=
LINK_PREVIEW_TIMEOUT_MS=
LINK_PREVIEW_MAX_BYTES=

# Weather. Open-Meteo needs NO key. Only set a key for OpenWeather.
WEATHER_PROVIDER=open-meteo
OPENWEATHER_API_KEY=

# Telegram bot (channels) — token from @BotFather; leave blank to disable Telegram
TELEGRAM_BOT_TOKEN=

# Email magic links — Resend; leave blank in dev to log links to console
RESEND_API_KEY=
MAGIC_LINK_FROM=

# Debug log panel (DEV ONLY) — set to 1 to tee server logs into a 🐞 panel in the web UI.
# Exposes raw server logs to any client; never enable in production. Blank/0/off = disabled.
DEBUG_LOG=

# ── User impersonation (HOST/ADMIN ONLY) ──
# Set to 1 to show a "Acting as" dropdown in the web header that loads and acts as ANY user (root +
# every Telegram account). Default OFF. DB + file isolation still hold — it only changes which user the
# web acts as. SECURITY: the web layer has NO auth, so with this ON anyone who can reach the server can
# act as any user via one request header. Keep OFF on any networked/multi-user deployment. Blank/0/off = disabled.
USER_IMPERSONATION=
